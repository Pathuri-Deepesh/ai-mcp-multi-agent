# MCP Agent - Environment Configuration
# Copy this file to .env and fill in the required values

# ============================================
# REQUIRED: Anthropic API Configuration
# ============================================
# Get your API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=eyJpZCI6ICIxOGNiYjQzNy00MmJiLTQ3YmEtYmQwZS1iYzY5NTk1OWM2MDkiLCAia2V5IjogImhqMnUtSk4wQnZOTHZRYzdqZnZDMEEiLCAiZXhwaXJlc19hdCI6IDE4MDQ5Mzc2OTQuOTM2Mzg1fQ

# ============================================
# REQUIRED: Weather API Configuration
# ============================================
# OpenWeatherMap API key (needed for real weather data)
# Get a FREE API key from: https://openweathermap.org/api
# Steps:
#   1. Go to https://openweathermap.org/api
#   2. Create a free account
#   3. Navigate to "API Keys" section
#   4. Copy your API key and paste it here
OPENWEATHER_API_KEY="47d69945bf5af6acf6aee7efcbfe14d7"

# ============================================
# OPTIONAL: Agent Configuration
# ============================================
# Claude model to use for the agent
# Options: claude-3-5-sonnet, claude-haiku-4-5-20251001, etc.
AGENT_MODEL=claude-haiku-4-5-20251001

# Streaming mode for agent responses
# Set to "true" for streaming responses, "false" for complete responses
STREAMING=true

# ============================================
# OPTIONAL: Logging Configuration
# ============================================
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path (optional, logs to console if not set)
# LOG_FILE=logs/agent.log

# ============================================
# OPTIONAL: Server Configuration
# ============================================
# Math server settings
MATH_SERVER_TRANSPORT=stdio

# Weather server settings
WEATHER_SERVER_TRANSPORT=stdio
WEATHER_SERVER_HOST=localhost
WEATHER_SERVER_PORT=8000

# ============================================
# OPTIONAL: Performance Settings
# ============================================
# Request timeout in seconds
REQUEST_TIMEOUT=30

# Maximum retries for failed operations
MAX_RETRIES=3

# Cache TTL in seconds (0 = no caching)
CACHE_TTL=300
